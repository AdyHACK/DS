
import pandas as pd

# Load dataset
df = pd.read_csv("iris.csv")

# Create categorical groups based on SepalLengthCm
df['sepal_group'] = pd.cut(
    df['SepalLengthCm'],
    bins=3,
    labels=["Low", "Medium", "High"]
)

# Group by categorical variable
grouped = df.groupby('sepal_group')['PetalLengthCm']

# Display statistics
print("Mean:\n", grouped.mean())

print("\nMedian:\n", grouped.median())

print("\nMinimum:\n", grouped.min())

print("\nMaximum:\n", grouped.max())

print("\nStandard Deviation:\n", grouped.std())

