# ===================== NLP TEXT PREPROCESSING + TF-IDF =====================

import nltk

# -------------------- DOWNLOAD REQUIRED NLTK DATA --------------------

nltk.download('punkt')
nltk.download('punkt_tab')
nltk.download('stopwords')
nltk.download('wordnet')
nltk.download('averaged_perceptron_tagger')
nltk.download('averaged_perceptron_tagger_eng')

# -------------------- IMPORT LIBRARIES --------------------

from nltk.tokenize import word_tokenize
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer, WordNetLemmatizer
from nltk import pos_tag

from sklearn.feature_extraction.text import TfidfVectorizer

# =====================================================================
# PART 1 : TEXT PREPROCESSING
# =====================================================================

text = "Text analytics is the process of analyzing text data to extract useful information."

print("========== TEXT PREPROCESSING ==========\n")

# -------------------- ORIGINAL TEXT --------------------

print("----- ORIGINAL TEXT -----")
print(text)

# -------------------- TOKENIZATION --------------------

tokens = word_tokenize(text)

print("\n----- TOKENS -----")
print(tokens)

# -------------------- POS TAGGING --------------------

pos = pos_tag(tokens)

print("\n----- POS TAGS -----")

for word, tag in pos:
    print(f"{word:<15} -> {tag}")

# -------------------- STOPWORD REMOVAL --------------------

stop_words = set(stopwords.words('english'))

filtered = [word for word in tokens if word.lower() not in stop_words]

print("\n----- AFTER STOPWORD REMOVAL -----")
print(filtered)

# -------------------- STEMMING --------------------

stemmer = PorterStemmer()

stemmed = [stemmer.stem(word) for word in filtered]

print("\n----- STEMMED WORDS -----")
print(stemmed)

# -------------------- LEMMATIZATION --------------------

lemmatizer = WordNetLemmatizer()

lemmatized = [lemmatizer.lemmatize(word) for word in filtered]

print("\n----- LEMMATIZED WORDS -----")
print(lemmatized)

# =====================================================================
# PART 2 : TF-IDF REPRESENTATION
# =====================================================================

documents = [
    "Text analytics is useful",
    "Text data analysis is important",
    "Analytics helps extract information"
]

print("\n\n========== TF-IDF REPRESENTATION ==========\n")

# -------------------- PRINT DOCUMENTS --------------------

print("----- DOCUMENTS -----")

for i, doc in enumerate(documents, 1):
    print(f"Doc {i}: {doc}")

# -------------------- CREATE TF-IDF VECTORIZER --------------------

vectorizer = TfidfVectorizer()

# -------------------- GENERATE TF-IDF MATRIX --------------------

tfidf_matrix = vectorizer.fit_transform(documents)

# -------------------- GET FEATURE NAMES --------------------

features = vectorizer.get_feature_names_out()

# -------------------- CONVERT MATRIX TO ARRAY --------------------

matrix = tfidf_matrix.toarray()

# -------------------- PRINT FEATURES --------------------

print("\n----- FEATURE NAMES -----")
print(features)

# -------------------- PRINT TF-IDF MATRIX --------------------

print("\n----- TF-IDF MATRIX -----")
print("Rows = Documents")
print("Columns = Words\n")

for i in range(len(matrix)):

    print(f"Doc {i+1}:\n")

    for j in range(len(features)):
        print(f"{features[j]:<15} : {matrix[i][j]:.3f}")

    print()








