import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

# Load dataset
df = sns.load_dataset("titanic")

# Print actual boxplot values
grouped = df.groupby(["sex", "survived"])["age"]

print("\n===== BOX PLOT VALUES =====\n")

for name, group in grouped:
    
    q1 = group.quantile(0.25)
    median = group.quantile(0.50)
    q3 = group.quantile(0.75)
    minimum = group.min()
    maximum = group.max()

    print(f"Group: {name}")
    print(f"Minimum Value : {minimum}")
    print(f"Q1 (Box Start): {q1}")
    print(f"Median        : {median}")
    print(f"Q3 (Box End)  : {q3}")
    print(f"Maximum Value : {maximum}")
    print("-" * 40)

# Create graph
plt.figure(figsize=(10,6))

sns.boxplot(
    x="sex",
    y="age",
    hue="survived",
    data=df
)

plt.title("Age Distribution by Gender and Survival")
plt.xlabel("Gender")
plt.ylabel("Age")

plt.show()
print("\n========== OBSERVATIONS ==========") 
print("1. Females have higher survival rate than males.") 
print("2. Children (lower age) have higher survival chances.") 
print("3. Male age distribution is wider than females.") 
print("4. Older passengers have lower survival rate.") 
print("5. Some outliers are present in age.")








